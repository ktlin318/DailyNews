{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ktlin318.github.io/DailyNews/data/schema.json",
  "title": "Daily Focus Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "date", "timezone", "generated_at", "source_window", "daily_overview", "topic_overviews", "topics", "audiences", "events", "audience_talk_tracks", "warnings", "manual_review_items"],
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "date": {"type": "string", "format": "date"},
    "timezone": {"const": "Asia/Taipei"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {"start": {"type": "string", "format": "date-time"}, "end": {"type": "string", "format": "date-time"}}
    },
    "daily_overview": {"type": "string", "minLength": 1},
    "topic_overviews": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string"}
    },
    "topics": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "audiences": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "events": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/event"}},
    "audience_talk_tracks": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/talkTrack"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "manual_review_items": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publisher", "title", "url", "published_at", "source_type"],
      "properties": {
        "publisher": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "published_at": {"type": "string", "minLength": 10},
        "source_type": {"enum": ["primary", "reporting", "issuer"]}
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "topic", "classification_reason", "time", "title", "summary", "impact", "keywords", "audiences", "sources", "evidence_notes"],
      "properties": {
        "event_id": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$"},
        "topic": {"type": "string", "minLength": 1},
        "time": {"type": "string", "minLength": 1},
        "published_date": {"type": "string", "format": "date"},
        "focus_score": {"type": "integer", "minimum": 0, "maximum": 100},
        "score_breakdown": {
          "type": "object",
          "additionalProperties": false,
          "required": ["importance", "cross_source_coverage", "homepage_or_popular", "audience_relevance", "recency"],
          "properties": {
            "importance": {"type": "integer", "minimum": 0, "maximum": 40},
            "cross_source_coverage": {"type": "integer", "minimum": 0, "maximum": 25},
            "homepage_or_popular": {"type": "integer", "minimum": 0, "maximum": 20},
            "audience_relevance": {"type": "integer", "minimum": 0, "maximum": 10},
            "recency": {"type": "integer", "minimum": 0, "maximum": 5}
          }
        },
        "selection_reason": {"type": "string", "minLength": 1},
        "classification_reason": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "impact": {"type": "string", "minLength": 1},
        "keywords": {"type": "array", "minItems": 2, "maxItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "audiences": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}},
        "evidence_notes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "talkTrack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opening", "questions"],
      "properties": {"opening": {"type": "string", "minLength": 1}, "questions": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "string", "minLength": 1}}}
    }
  }
}
